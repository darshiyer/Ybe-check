{
  "name": "ybe-check",
  "displayName": "Ybe Check",
  "description": "Security scanner for AI-generated code \u2014 10 scan modules, MCP server, VS Code sidebar",
  "version": "1.0.0",
  "publisher": "YbeCheck",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Linters",
    "Testing",
    "Other"
  ],
  "keywords": [
    "security",
    "audit",
    "scanner",
    "vibe-coded",
    "production-readiness",
    "MCP",
    "copilot",
    "secrets",
    "SBOM",
    "compliance"
  ],
  "galleryBanner": {
    "color": "#0a0a0b",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AddyCuber/A2K2-PS1"
  },
  "homepage": "https://github.com/AddyCuber/A2K2-PS1#readme",
  "bugs": {
    "url": "https://github.com/AddyCuber/A2K2-PS1/issues"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ybe-check.fullScan",
        "title": "Ybe Check: Full Audit (Static + Dynamic)",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.staticScan",
        "title": "Ybe Check: Static Scan",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.askCopilot",
        "title": "Ybe Check: Ask Copilot (with Security Context)",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.fixWithCopilot",
        "title": "Ybe Check: Fix Finding with Copilot",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.securityAudit",
        "title": "Ybe Check: Security Audit with Copilot",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.explainFinding",
        "title": "Ybe Check: Explain Finding (Educational)",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.reviewFile",
        "title": "Ybe Check: Review Current File with Copilot",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.fixAllCritical",
        "title": "Ybe Check: Fix All Critical/High Findings",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.fixCurrentFile",
        "title": "Ybe Check: Fix All Issues in Current File",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.secureImplementation",
        "title": "Ybe Check: Secure Implementation Helper",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.browseBySeverity",
        "title": "Ybe Check: Browse Findings by Severity",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.installMcp",
        "title": "Ybe Check: Refresh MCP Config",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.openDashboard",
        "title": "Ybe Check: Open Full Dashboard (localhost)",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.runSidebarScan",
        "title": "Ybe Check: Run Scan",
        "icon": "$(play)"
      },
      {
        "command": "ybe-check.scanChanged",
        "title": "Ybe Check: Scan Changed Files (git diff)",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.scanFile",
        "title": "Ybe Check: Scan this File",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.scanFolder",
        "title": "Ybe Check: Scan this Folder",
        "category": "Ybe Check"
      },
      {
        "command": "ybe-check.toggleAutoScan",
        "title": "Ybe Check: Toggle Auto-Scan on Save"
      },
      {
        "command": "ybe-check.exportReport",
        "title": "Ybe Check: Export Report"
      }
    ],
    "configuration": {
      "title": "Ybe Check",
      "properties": {
        "ybe-check.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python executable."
        },
        "ybe-check.excludePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Glob patterns (relative to repo root) to exclude from all scans. Example: [\"legacy/**\", \"vendor/**\", \"generated/**\"]"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ybe-check-sidebar",
          "title": "Ybe Check",
          "icon": "media/shield.svg"
        }
      ]
    },
    "views": {
      "ybe-check-sidebar": [
        {
          "type": "webview",
          "id": "ybeCheck.sidebar",
          "name": "Security Scanner",
          "icon": "media/shield.svg",
          "contextualTitle": "Ybe Check"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ybe-check.runSidebarScan",
          "when": "view == ybeCheck.sidebar",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "ybe-check.scanFile",
          "when": "!explorerResourceIsFolder",
          "group": "ybe-check@1"
        },
        {
          "command": "ybe-check.scanFolder",
          "when": "explorerResourceIsFolder",
          "group": "ybe-check@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ybe-check.runSidebarScan",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "ybe-check.staticScan",
        "key": "ctrl+shift+alt+y",
        "mac": "cmd+shift+alt+y",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "ybe-check.openDashboard",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "workspaceFolderCount > 0"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run compile",
    "package": "vsce package",
    "package:rc": "vsce package --pre-release",
    "publish": "vsce publish",
    "publish:rc": "vsce publish --pre-release"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^8.28.0",
    "typescript": "^4.9.3"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "fs-extra": "^11.3.3"
  }
}